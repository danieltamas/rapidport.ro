# ---------------------------------------------------------------------------
# worker/.dockerignore — Python worker Docker build context exclusions
# Keep pyproject.toml + src/ in context; exclude everything else below.
# ---------------------------------------------------------------------------

# Python bytecode & caches
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/

# Test & type-checking caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Distribution / build artifacts
dist/
*.egg-info/
build/
*.so

# Coverage reports
.coverage
.coverage.*
htmlcov/
coverage.xml

# Test files (not needed at runtime)
tests/

# Editor / IDE metadata
.vscode/
.idea/
*.swp
*.swo
*~

# OS artifacts
.DS_Store
Thumbs.db

# Version control (not needed in image)
.git/
.gitignore

# Documentation (not needed at runtime)
README.md

# Secrets / environment files (never bake into image)
.env
.env.*

# Python version pin file (runtime image already pins 3.12)
.python-version
