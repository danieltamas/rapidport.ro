# Rapidport — environment variables
# Copy to .env and fill in real values. .env is gitignored.
NODE_ENV=development

# APP_URL is the public-facing origin.
# With rundev's reverse proxy terminating SSL at rapidport.ro locally, use the prod domain.
# Without a reverse proxy, uncomment the localhost fallback instead.
APP_URL=https://rapidport.ro
# APP_URL=http://localhost:3015

# DATABASE_URL=postgresql://user:pass@localhost:5432/rapidport?sslmode=require
