# Rapidport — environment variables
# Copy to .env and fill in real values. .env is gitignored.
NODE_ENV=development

# APP_URL is the public-facing origin.
# With rundev's reverse proxy terminating SSL at rapidport.ro locally, use the prod domain.
# Without a reverse proxy, uncomment the localhost fallback instead.
APP_URL=https://rapidport.ro
# APP_URL=http://localhost:3015

# DATABASE_URL is required — Drizzle and pg-boss won't start without it.
# Format: postgresql://user:pass@host:port/db?sslmode=require
DATABASE_URL=postgresql://user:pass@localhost:5432/rapidport?sslmode=require

# ADMIN_EMAILS — comma-separated allowlist of admin Google emails (lowercased).
# Dev default is a non-working placeholder; set a real value in production.
# ADMIN_EMAILS=admin@example.com,admin2@example.com

# Resend (transactional email)
RESEND_API_KEY=re_...
EMAIL_FROM=Rapidport <no-reply@rapidport.ro>

# Google OAuth (admin login)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://rapidport.ro/api/auth/google/callback

# Stripe — payments. Use sk_test_/pk_test_ for staging, sk_live_/pk_live_ in prod.
# STRIPE_WEBHOOK_SECRET comes from `stripe listen` (dev) or the dashboard endpoint config (prod).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SmartBill — invoicing (Gamerina SRL, series RAPIDPORT).
SMARTBILL_USERNAME=you@gamerina.ro
SMARTBILL_API_KEY=...
SMARTBILL_CIF=RO...           # Gamerina SRL CIF including 'RO' prefix
SMARTBILL_SERIES=RAPIDPORT

# Scheduled jobs (cleanup cron + sweeps). Defaults: on in production, OFF in
# development (pg-boss + worker subscribers add ~hundreds of MB to dev RAM and
# aren't needed while iterating on UI). Set SCHEDULER_ENABLED=true to force-on.
# SCHEDULER_ENABLED=true
